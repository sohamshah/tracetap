+    /**
+     * Strip per-call volatile fragments from text (timestamps, IDE cwd, system reminders,
+     * Claude Code v2 billing-header cache hash `cch=...;`).
+     */
+    private normalizeVolatileText(text: string): string {
+        text = text.replace(/Generated \d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}/g, "Generated [TIMESTAMP]");
+        text = text.replace(/The user opened the file [^\s]+ in the IDE\./g, "The user opened file in IDE.");
+        text = text.replace(/<system-reminder>.*?<\/system-reminder>/gs, "[SYSTEM-REMINDER]");
+        text = text.replace(/cch=[0-9a-f]+;?/g, "cch=[HASH];");
+        return text;
+    }
+
+    /**
+     * Normalize the system field for grouping. Strips cache_control variations and
+     * volatile billing-header text so identical conversations group together even when
+     * the SDK shuffles cache_control TTLs or rotates per-call hashes.
+     */
+    private normalizeSystemForGrouping(system: any): any {
+        if (system == null) return null;
+        if (typeof system === "string") return this.normalizeVolatileText(system);
+        if (Array.isArray(system)) {
+            return system.map((block) => {
+                if (!block || typeof block !== "object") return block;
+                const next: Record<string, any> = {};
+                for (const [k, v] of Object.entries(block)) {
+                    if (k === "cache_control") continue; // varies between calls; not semantic
+                    next[k] = v;
+                }
+                if (next.type === "text" && typeof next.text === "string") {
+                    next.text = this.normalizeVolatileText(next.text);
+                }
+                return next;
+            });
+        }
+        return system;
+    }
