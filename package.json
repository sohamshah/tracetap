{
  "name": "claude-trace-v2",
  "version": "0.1.2",
  "description": "Record Claude Code v2 traffic (request bodies, system prompts, tools, streamed responses) into a JSONL log and a self-contained HTML viewer, by proxying ANTHROPIC_BASE_URL through a local HTTP server.",
  "main": "dist/index.js",
  "bin": {
    "claude-trace-v2": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "files": [
    "dist/**/*",
    "frontend/dist/**/*",
    "frontend/template.html",
    "frontend/patches/**/*",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "logging",
    "trace",
    "api",
    "proxy",
    "debugging",
    "observability"
  ],
  "license": "MIT",
  "author": "Soham Shah",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sohamshah/claude-trace-v2.git"
  },
  "homepage": "https://github.com/sohamshah/claude-trace-v2#readme",
  "bugs": {
    "url": "https://github.com/sohamshah/claude-trace-v2/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
